#!/usr/bin/env python3
"""
neorev — human review for agent diffs.

Usage:
    jj show XXX | neorev for_agent.txt
    jj show XXX | neorev --clip for_agent.txt
    git diff HEAD~1 | neorev review.txt

Reads a unified diff from stdin, renders each hunk through `delta` for
pretty display, and lets you annotate hunks interactively. On quit,
writes a compact annotated review to the given output file.

If the output file already exists, previous annotations are loaded and
applied to matching hunks, so you can resume or refine a review.

Keys:
    j / ↓         Next hunk
    k / ↑         Previous hunk
    Ctrl-D        Scroll diff down (half page)
    Ctrl-U        Scroll diff up (half page)
    a             Approve hunk (no comment needed)
    A             Approve all hunks in current file
    c             Question about this hunk (opens $EDITOR)
    f             Flag hunk: request a change (opens $EDITOR)
    gc            Global question, not tied to a specific hunk
    gf            Global flag (request a change), not tied to a specific hunk
    q / Ctrl-C    Quit and write output to file
    ?             Show help
"""

import argparse
import base64
import os
import re
import subprocess
import sys
import tempfile
import termios
import tty
from dataclasses import dataclass
from io import StringIO

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

CSI = "\033["
CLEAR_SCREEN = f"{CSI}2J{CSI}H"
BOLD = f"{CSI}1m"
DIM = f"{CSI}2m"
RESET = f"{CSI}0m"
GREEN = f"{CSI}32m"
RED = f"{CSI}31m"
YELLOW = f"{CSI}33m"
CYAN = f"{CSI}36m"
BG_BLUE = f"{CSI}44m"
WHITE = f"{CSI}37m"

ALT_SCREEN_ON = f"{CSI}?1049h"
ALT_SCREEN_OFF = f"{CSI}?1049l"
CURSOR_HIDE = f"{CSI}?25l"
CURSOR_SHOW = f"{CSI}?25h"

ANSI_ESCAPE_RE = re.compile(rb"\x1b\[[0-9;]*[a-zA-Z]")
ANSI_ESCAPE_TEXT_RE = re.compile(r"\x1b\[[0-9;]*[a-zA-Z]")

OUTPUT_PREAMBLE = """\
# Code Review
#
# Instructions for the agent:
# - CHANGE REQUESTED → apply the requested change.
# - QUESTION → answer the question; do NOT change code unless your answer
#   warrants it.
# - Global notes do not apply to a specific part of the diff. They may
#   refer to the change as a whole, or to something outside of it.
#
"""

# ---------------------------------------------------------------------------
# Data classes
# ---------------------------------------------------------------------------


@dataclass
class Hunk:
    """A single diff hunk with optional review annotation."""

    file_header: str
    range_line: str
    body: str
    raw: str
    file_path: str = ""
    start_line: int = 0
    comment: str = ""
    status: str = ""

    @property
    def short_location(self) -> str:
        """Return a compact 'file:line' location string."""
        return (
            f"{self.file_path}:{self.start_line}"
            if self.file_path
            else self.range_line.strip()
        )


@dataclass
class GlobalNote:
    """A review annotation not tied to any specific hunk."""

    kind: str  # "flag" or "question"
    text: str


@dataclass
class ReviewState:
    """Mutable state for the interactive review session."""

    hunks: list[Hunk]
    global_notes: list[GlobalNote]
    current_index: int = 0
    scroll_offset: int = 0


@dataclass(frozen=True)
class DiffViewport:
    """Describes which diff lines are visible in the current terminal viewport."""

    scroll_offset: int
    visible_line_count: int
    total_lines: int
    can_scroll_up: bool
    can_scroll_down: bool
    lines_above: int
    lines_below: int


# ---------------------------------------------------------------------------
# Diff parsing
# ---------------------------------------------------------------------------


def parse_diff(diff_text: str) -> list[Hunk]:
    """Parse a unified diff into a list of reviewable hunks."""
    hunks: list[Hunk] = []
    lines = diff_text.splitlines(keepends=True)
    current_file_header = ""
    current_file_path = ""
    i = 0

    while i < len(lines):
        line = lines[i]

        if line.startswith("diff --git") or line.startswith("diff "):
            current_file_header, current_file_path, i = _parse_file_header(
                lines, i, current_file_path
            )
            continue

        if line.startswith("@@"):
            hunk, i = _parse_hunk_body(lines, i, current_file_header, current_file_path)
            hunks.append(hunk)
            continue

        i += 1

    return hunks


def _parse_file_header(
    lines: list[str], start: int, current_file_path: str
) -> tuple[str, str, int]:
    """Parse a diff file header block starting at *start*.

    Returns (file_header, file_path, next_line_index).
    """
    header_lines = [lines[start]]
    i = start + 1
    file_path = current_file_path
    while (
        i < len(lines)
        and not lines[i].startswith("@@")
        and not lines[i].startswith("diff ")
    ):
        header_lines.append(lines[i])
        if lines[i].startswith("+++ "):
            path = lines[i][4:].strip()
            if path.startswith("b/"):
                path = path[2:]
            file_path = path
        i += 1
    file_header = "".join(header_lines).rstrip("\n")
    return file_header, file_path, i


def _parse_hunk_body(
    lines: list[str], start: int, file_header: str, file_path: str
) -> tuple[Hunk, int]:
    """Parse a single @@ hunk starting at *start*.

    Returns (Hunk, next_line_index).
    """
    range_line = lines[start].rstrip("\n")
    match = re.search(r"\+(\d+)", range_line)
    start_line = int(match.group(1)) if match else 0

    body_lines: list[str] = []
    i = start + 1
    while (
        i < len(lines)
        and not lines[i].startswith("@@")
        and not lines[i].startswith("diff ")
    ):
        body_lines.append(lines[i])
        i += 1

    body = "".join(body_lines).rstrip("\n")
    raw = (
        f"{file_header}\n{range_line}\n{body}"
        if file_header
        else f"{range_line}\n{body}"
    )

    hunk = Hunk(
        file_header=file_header,
        range_line=range_line,
        body=body,
        raw=raw,
        file_path=file_path,
        start_line=start_line,
    )
    return hunk, i


# ---------------------------------------------------------------------------
# Delta rendering
# ---------------------------------------------------------------------------


def render_through_delta(diff_text: str, width: int = 120) -> bytes:
    """Pipe *diff_text* through ``delta`` and return raw bytes (with ANSI)."""
    try:
        result = subprocess.run(
            [
                "delta",
                "--width",
                str(width),
                "--file-style",
                "omit",
                "--hunk-header-style",
                "omit",
                "--paging",
                "never",
            ],
            input=diff_text.encode(),
            capture_output=True,
            timeout=5,
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass
    return diff_text.encode()


# ---------------------------------------------------------------------------
# Output formatting (compact, agent-friendly)
# ---------------------------------------------------------------------------


def format_output(hunks: list[Hunk], global_notes: list[GlobalNote]) -> str:
    """Produce compact, unambiguous review output for an LLM agent.

    Approved hunks are omitted.  Questions and flags include a short diff
    snippet plus the reviewer's comment.  Global notes appear first.
    """
    out = StringIO()
    actionable = [h for h in hunks if h.status in ("question", "flag")]

    if not actionable and not global_notes:
        approved = sum(1 for h in hunks if h.status == "approved")
        out.write("# Review: all clear, no action needed.\n")
        out.write(f"# {approved}/{len(hunks)} hunks approved.\n")
        out.write(f"# neorev:{_encode_approved_bitmap(hunks)}\n")
        return out.getvalue()

    approved = sum(1 for h in hunks if h.status == "approved")
    flags = sum(1 for h in hunks if h.status == "flag")
    questions = sum(1 for h in hunks if h.status == "question")
    out.write(OUTPUT_PREAMBLE)
    out.write(
        f"# {len(hunks)} hunks: {approved} approved, "
        f"{questions} questions, {flags} changes requested\n"
    )
    if global_notes:
        out.write(f"# {len(global_notes)} global note(s)\n")
    out.write("\n")

    for note in global_notes:
        _write_global_note(out, note)

    for hunk in actionable:
        _write_hunk_annotation(out, hunk)

    out.write(f"# neorev:{_encode_approved_bitmap(hunks)}\n")
    return out.getvalue()


def _write_global_note(out: StringIO, note: GlobalNote) -> None:
    """Write a single global note section to *out*."""
    label = "CHANGE REQUESTED" if note.kind == "flag" else "QUESTION"
    out.write(f"## [{label}] (global)\n")
    for comment_line in note.text.splitlines():
        out.write(f"> {comment_line}\n")
    out.write("\n")


def _write_hunk_annotation(out: StringIO, hunk: Hunk) -> None:
    """Write a single hunk annotation section to *out*."""
    action = "CHANGE REQUESTED" if hunk.status == "flag" else "QUESTION"
    out.write(f"## [{action}] {hunk.file_path}\n")

    body_lines = hunk.body.splitlines()
    if len(body_lines) > 10:
        trimmed = body_lines[:5] + ["# ..."] + body_lines[-5:]
    else:
        trimmed = body_lines

    out.write("```diff\n")
    out.write(f"{hunk.range_line}\n")
    out.write("\n".join(trimmed))
    out.write("\n```\n")

    for comment_line in hunk.comment.splitlines():
        out.write(f"> {comment_line}\n")
    out.write("\n")


def _encode_approved_bitmap(hunks: list[Hunk]) -> str:
    """Encode the approved/pending state of *hunks* as a base64 string."""
    bits = bytearray()
    current_byte = 0
    bit_index = 0
    for hunk in hunks:
        if hunk.status == "approved":
            current_byte |= 1 << bit_index
        bit_index += 1
        if bit_index == 8:
            bits.append(current_byte)
            current_byte = 0
            bit_index = 0
    if bit_index:
        bits.append(current_byte)
    return base64.b64encode(bytes(bits)).decode("ascii")


def _decode_approved_bitmap(encoded: str, num_hunks: int) -> list[bool]:
    """Decode a base64 bitmap into a list of booleans (one per hunk).

    Returns an empty list if *encoded* is invalid or the length does not
    match *num_hunks*.
    """
    try:
        bits = base64.b64decode(encoded)
    except Exception:
        return []
    expected_bytes = (num_hunks + 7) // 8
    if len(bits) != expected_bytes:
        return []
    result: list[bool] = []
    for i in range(num_hunks):
        byte_idx, bit_idx = divmod(i, 8)
        result.append(bool(bits[byte_idx] & (1 << bit_idx)))
    return result


# ---------------------------------------------------------------------------
# Loading previous review from output file
# ---------------------------------------------------------------------------


def load_previous_review(
    path: str,
) -> tuple[dict[tuple[str, str], tuple[str, str]], list[GlobalNote], str]:
    """Parse a previous review output file.

    Returns a mapping of ``(file_path, range_line) → (status, comment)``
    for hunk annotations, a list of ``GlobalNote`` for global ones, and
    the raw approved-bitmap string (empty if absent).
    """
    try:
        with open(path) as f:
            text = f.read()
    except (FileNotFoundError, OSError):
        return {}, [], ""

    if not text.strip():
        return {}, [], ""

    annotations: dict[tuple[str, str], tuple[str, str]] = {}
    global_notes: list[GlobalNote] = []
    bitmap_encoded = ""

    bitmap_match = re.search(r"^# neorev:(\S+)$", text, re.MULTILINE)
    if bitmap_match:
        bitmap_encoded = bitmap_match.group(1)

    sections = re.split(r"^## ", text, flags=re.MULTILINE)

    for section in sections:
        if not section.strip():
            continue

        header_match = re.match(r"\[(CHANGE REQUESTED|QUESTION)\]\s+(.+)", section)
        if not header_match:
            continue

        action_str = header_match.group(1)
        target = header_match.group(2).strip()
        status = "flag" if action_str == "CHANGE REQUESTED" else "question"

        comment = _extract_comment_lines(section)

        if target == "(global)":
            if comment:
                global_notes.append(GlobalNote(kind=status, text=comment))
            continue

        range_match = re.search(r"```diff\n(@@[^\n]+)", section)
        if not range_match:
            continue
        range_line = range_match.group(1)

        annotations[(target, range_line)] = (status, comment)

    return annotations, global_notes, bitmap_encoded


def _extract_comment_lines(section: str) -> str:
    """Extract ``> ``-prefixed comment lines from a review section."""
    comment_lines: list[str] = []
    for line in section.splitlines():
        if line.startswith("> "):
            comment_lines.append(line[2:])
        elif line == ">":
            comment_lines.append("")
    return "\n".join(comment_lines).strip()


def apply_previous_review(
    hunks: list[Hunk], annotations: dict[tuple[str, str], tuple[str, str]]
) -> int:
    """Apply previously saved annotations to *hunks*.

    Returns the number of annotations that matched.
    """
    matched = 0
    for hunk in hunks:
        key = (hunk.file_path, hunk.range_line)
        if key in annotations:
            hunk.status, hunk.comment = annotations[key]
            matched += 1
    return matched


# ---------------------------------------------------------------------------
# Terminal helpers
# ---------------------------------------------------------------------------

_tty_out: int = -1  # fd for writing to terminal


def tty_write(data: bytes | str) -> None:
    """Write raw bytes or a string to the terminal display."""
    if isinstance(data, str):
        data = data.encode()
    os.write(_tty_out, data)


def read_key(fd: int) -> str:
    """Read one keypress from *fd*, normalising arrow-key escape sequences."""
    ch = os.read(fd, 1)
    if ch == b"\x1b":
        seq = os.read(fd, 2)
        if seq == b"[A":
            return "up"
        if seq == b"[B":
            return "down"
        return "esc"
    return ch.decode("utf-8", errors="replace")


# ---------------------------------------------------------------------------
# Comment editing
# ---------------------------------------------------------------------------


def edit_comment(existing: str, location: str) -> str:
    """Edit a review comment using ``$EDITOR`` or an inline TTY prompt."""
    editor = os.environ.get("EDITOR", "")
    if editor:
        return _edit_comment_in_editor(existing, location, editor)
    return _prompt_inline_comment(existing, location)


def _edit_comment_in_editor(existing: str, location: str, editor: str) -> str:
    """Open *editor* with a temporary file pre-filled with *existing*."""
    with tempfile.NamedTemporaryFile(
        mode="w", suffix=".md", prefix="review-", delete=False
    ) as tmp:
        jump_line = _write_comment_template(tmp, location, existing)
        tmppath = tmp.name

    try:
        with open("/dev/tty", "r") as tty_r, open("/dev/tty", "w") as tty_w:
            subprocess.run(
                [editor, f"{tmppath}:{jump_line}"],
                check=True,
                stdin=tty_r,
                stdout=tty_w,
                stderr=tty_w,
            )
        return _read_comment_file(tmppath)
    finally:
        os.unlink(tmppath)


def _write_comment_template(
    file_obj: "tempfile._TemporaryFileWrapper[str]",
    location: str,
    existing: str,
) -> int:
    """Write the comment template into *file_obj*.

    Returns the editor jump-line number (1-indexed).
    """
    file_obj.write(f"# Comment for {location}\n")
    file_obj.write("# Lines starting with # are stripped.\n\n")
    if existing:
        file_obj.write(existing)
    file_obj.write("\n")
    content_lines = existing.count("\n") + 1 if existing else 1
    return 3 + content_lines  # 2 comment lines + 1 blank + content


def _read_comment_file(path: str) -> str:
    """Read a comment file, stripping lines that start with ``#``."""
    with open(path) as f:
        lines = [line for line in f.readlines() if not line.startswith("#")]
    return "".join(lines).strip()


def _prompt_inline_comment(existing: str, location: str) -> str:
    """Prompt for a single-line comment directly on the TTY."""
    prompt = f"\r\n  Comment for {location}"
    if existing:
        prompt += f" [{existing}]"
    prompt += ": "
    tty_write(prompt)

    with open("/dev/tty", "r") as tty_r:
        fd = tty_r.fileno()
        old = termios.tcgetattr(fd)
        cooked = termios.tcgetattr(fd)
        cooked[3] |= termios.ECHO | termios.ICANON
        termios.tcsetattr(fd, termios.TCSADRAIN, cooked)
        line = tty_r.readline().strip()
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
    return line if line else existing


# ---------------------------------------------------------------------------
# Navigation helpers
# ---------------------------------------------------------------------------


def find_next_unhandled_hunk(hunks: list[Hunk], current: int) -> int:
    """Find the next hunk with no status, wrapping around.

    Returns *current* if every hunk has been handled.
    """
    n = len(hunks)
    for offset in range(1, n + 1):
        candidate = (current + offset) % n
        if hunks[candidate].status == "":
            return candidate
    return current


def find_initial_hunk_index(hunks: list[Hunk]) -> int:
    """Return the index of the first unhandled hunk, or 0."""
    for i, hunk in enumerate(hunks):
        if hunk.status == "":
            return i
    return 0


# ---------------------------------------------------------------------------
# Layout helpers (pure — no TTY side effects)
# ---------------------------------------------------------------------------


def visible_text_length(line: bytes) -> int:
    """Return the visible character count of *line* (ignoring ANSI escapes)."""
    stripped = ANSI_ESCAPE_RE.sub(b"", line)
    try:
        return len(stripped.decode("utf-8", errors="replace"))
    except Exception:
        return len(stripped)


def estimate_wrapped_rows(line: bytes, term_width: int) -> int:
    """Estimate how many terminal rows *line* occupies after wrapping."""
    vlen = visible_text_length(line)
    if vlen == 0:
        return 1
    return (vlen + term_width - 1) // term_width


def count_fitting_lines(line_rows: list[int], start: int, row_budget: int) -> int:
    """Count how many diff lines fit within *row_budget* rows from *start*."""
    used = 0
    count = 0
    for i in range(start, len(line_rows)):
        needed = line_rows[i]
        if used + needed > row_budget:
            break
        used += needed
        count += 1
    return count


def wrap_ansi_line_to_rows(line: bytes, term_width: int) -> list[bytes]:
    """Split one ANSI-colored line into terminal-width display rows."""
    if term_width <= 1:
        return [line]

    text = line.decode("utf-8", errors="replace")
    chunks: list[str] = []
    current: list[str] = []
    visible = 0
    active_sgr: list[str] = []

    def flush_chunk() -> None:
        nonlocal current, visible
        if active_sgr:
            current.append(RESET)
        chunks.append("".join(current))
        current = list(active_sgr)
        visible = 0

    def append_plain(plain: str) -> None:
        nonlocal visible
        for ch in plain:
            if visible >= term_width:
                flush_chunk()
            current.append(ch)
            visible += 1

    pos = 0
    for match in ANSI_ESCAPE_TEXT_RE.finditer(text):
        append_plain(text[pos : match.start()])
        esc = match.group(0)
        current.append(esc)
        if esc.endswith("m"):
            if esc in (f"{CSI}0m", f"{CSI}m"):
                active_sgr.clear()
            else:
                active_sgr.append(esc)
        pos = match.end()
    append_plain(text[pos:])

    if current or not chunks:
        chunks.append("".join(current))

    return [chunk.encode("utf-8", errors="replace") for chunk in chunks]


def build_display_lines(delta_output: bytes, term_width: int) -> list[bytes]:
    """Return physical terminal rows for rendered diff output."""
    raw_lines = delta_output.split(b"\n")

    # Delta output ends with a trailing newline; ``split`` would otherwise add
    # a synthetic empty line that shows up as a visual gap above the footer.
    if raw_lines and raw_lines[-1] == b"":
        raw_lines = raw_lines[:-1]

    display_lines: list[bytes] = []
    for line in raw_lines:
        display_lines.extend(wrap_ansi_line_to_rows(line, term_width))

    return display_lines or [b""]


def compute_diff_viewport(
    line_rows: list[int],
    term_height: int,
    scroll_offset: int,
) -> DiffViewport:
    """Compute which diff lines are visible given the terminal geometry.

    The fixed chrome occupies 3 rows (top bar + markers + footer).
    Scroll indicators are reserved only when actually needed.
    """
    total_lines = len(line_rows)
    total_content_rows = sum(line_rows)
    base_chrome = 3  # top bar + markers + footer
    max_avail = term_height - base_chrome

    needs_scrolling = total_content_rows > max_avail

    if needs_scrolling:
        avail_at_bottom = max(max_avail - 1, 3)
        max_offset = 0
        for i in range(total_lines):
            if sum(line_rows[i:]) <= avail_at_bottom:
                max_offset = i
                break
        else:
            max_offset = total_lines - 1
        scroll_offset = min(scroll_offset, max(0, max_offset))

        can_scroll_up = scroll_offset > 0
        can_scroll_down = scroll_offset < max_offset

        indicator_rows = (1 if can_scroll_up else 0) + (1 if can_scroll_down else 0)
        avail_rows = max(max_avail - indicator_rows, 3)
        visible_count = count_fitting_lines(line_rows, scroll_offset, avail_rows)
    else:
        scroll_offset = 0
        can_scroll_up = False
        can_scroll_down = False
        visible_count = count_fitting_lines(line_rows, 0, max_avail)

    lines_above = scroll_offset
    lines_below = total_lines - scroll_offset - visible_count

    return DiffViewport(
        scroll_offset=scroll_offset,
        visible_line_count=visible_count,
        total_lines=total_lines,
        can_scroll_up=can_scroll_up,
        can_scroll_down=can_scroll_down,
        lines_above=lines_above,
        lines_below=lines_below,
    )


def build_top_bar(
    hunk: Hunk,
    current_index: int,
    total_hunks: int,
    global_note_count: int,
) -> str:
    """Build the top status bar string for the current hunk."""
    status_map = {
        "approved": f"{GREEN}✓ approved{RESET}",
        "flag": f"{RED}✗ change requested{RESET}",
        "question": f"{YELLOW}? question{RESET}",
        "": f"{DIM}—{RESET}",
    }
    status_str = status_map.get(hunk.status, f"{DIM}—{RESET}")

    comment_bit = ""
    if hunk.comment:
        preview = hunk.comment.replace("\n", " ")
        if len(preview) > 60:
            preview = preview[:60] + "…"
        comment_bit = f"  {YELLOW}\U000f0184 {preview}{RESET}"

    global_bit = ""
    if global_note_count:
        global_bit = f"  {CYAN}[{global_note_count} global]{RESET}"

    return (
        f"{BOLD}{WHITE}{BG_BLUE} neorev {RESET}  "
        f"Hunk {BOLD}{current_index + 1}{RESET}/{total_hunks}  "
        f"{DIM}│{RESET} {BOLD}{hunk.short_location}{RESET}  "
        f"{DIM}│{RESET} {status_str}"
        f"{comment_bit}"
        f"{global_bit}"
    )


def _hunk_marker(hunk: Hunk, is_current: bool) -> str:
    """Return the ANSI-styled marker for a single hunk (3 visible chars)."""
    icon = "·"
    color = DIM
    if hunk.status == "approved":
        icon, color = "✓", GREEN
    elif hunk.status == "flag":
        icon, color = "✗", RED
    elif hunk.status == "question":
        icon, color = "?", YELLOW
    if is_current:
        return f"{BOLD}[{color}{icon}{RESET}{BOLD}]{RESET}"
    return f" {color}{icon}{RESET} "


def build_progress_markers(
    hunks: list[Hunk], current_index: int, term_width: int
) -> str:
    """Build the hunk progress marker line, with overflow arrows."""
    total = len(hunks)
    prefix = "  "
    prefix_width = 2
    marker_width = 3  # each marker is 3 visible chars
    arrow_width = 2  # "◀ " or " ▶"

    available = term_width - prefix_width
    max_markers = available // marker_width

    if max_markers >= total:
        # Everything fits – no arrows needed.
        markers = [_hunk_marker(hunks[i], i == current_index) for i in range(total)]
        return prefix + "".join(markers)

    # We need arrows; compute how many markers fit with arrow slots.
    # Start with both arrows reserved, then drop unneeded ones after windowing.
    slots = (available - arrow_width * 2) // marker_width
    slots = max(slots, 1)

    # Centre the window on current_index.
    half = slots // 2
    start = current_index - half
    end = start + slots

    # Clamp to valid range.
    if start < 0:
        start, end = 0, slots
    if end > total:
        end = total
        start = max(0, end - slots)

    need_left = start > 0
    need_right = end < total

    # If only one arrow is needed, reclaim the space from the other.
    if not need_left or not need_right:
        extra = (
            available - (arrow_width if need_left or need_right else 0)
        ) // marker_width
        extra = max(extra, 1)
        if extra > slots:
            slots = min(extra, total)
            half = slots // 2
            start = current_index - half
            end = start + slots
            if start < 0:
                start, end = 0, slots
            if end > total:
                end = total
                start = max(0, end - slots)
            need_left = start > 0
            need_right = end < total

    markers = [_hunk_marker(hunks[i], i == current_index) for i in range(start, end)]
    left = f"{DIM}◀ {RESET}" if need_left else ""
    right = f"{DIM} ▶{RESET}" if need_right else ""
    return prefix + left + "".join(markers) + right


# ---------------------------------------------------------------------------
# Screen rendering
# ---------------------------------------------------------------------------


def render_review_screen(
    hunks: list[Hunk],
    current_index: int,
    delta_output: bytes,
    term_width: int,
    term_height: int,
    global_notes: list[GlobalNote],
    scroll_offset: int = 0,
) -> int:
    """Render the full review screen and return the clamped scroll offset."""
    hunk = hunks[current_index]
    diff_lines = build_display_lines(delta_output, term_width)
    line_rows = [1] * len(diff_lines)
    viewport = compute_diff_viewport(line_rows, term_height, scroll_offset)

    tty_write(CLEAR_SCREEN)

    top_bar = build_top_bar(hunk, current_index, len(hunks), len(global_notes))
    tty_write(top_bar + "\r\n")

    tty_write(build_progress_markers(hunks, current_index, term_width) + "\r\n")

    _render_diff_body(diff_lines, viewport)
    _render_footer(term_height, term_width, viewport)

    return viewport.scroll_offset


def _render_diff_body(diff_lines: list[bytes], viewport: DiffViewport) -> None:
    """Render the visible diff lines with scroll indicators."""
    if viewport.can_scroll_up:
        tty_write(
            f"  {BOLD}{WHITE}▲ Ctrl-U to scroll up "
            f"({viewport.lines_above} lines above){RESET}\r\n"
        )

    start = viewport.scroll_offset
    end = start + viewport.visible_line_count
    for line in diff_lines[start:end]:
        tty_write(line)
        tty_write(b"\r\n")


def _render_footer(term_height: int, term_width: int, viewport: DiffViewport) -> None:
    """Render the scroll-down indicator and bottom key hints."""
    if viewport.can_scroll_down:
        tty_write(f"{CSI}{term_height - 1};1H")
        tty_write(
            f"  {BOLD}{WHITE}▼ Ctrl-D to scroll down "
            f"({viewport.lines_below} lines below){RESET}"
        )

    tty_write(f"{CSI}{term_height};1H")
    footer = _build_footer_line(term_width)
    tty_write(footer)


def _build_footer_line(term_width: int) -> str:
    """Build a key-hints footer line truncated to *term_width* visible chars."""
    segments = [
        ("j/k", "navigate"),
        ("a", "approve"),
        ("A", "approve file"),
        ("c", "question"),
        ("f", "flag"),
        ("gc/gf", "global"),
        ("q", "quit & save"),
        ("?", "help"),
    ]
    parts: list[str] = []
    visible_len = 0
    truncated = False
    for i, (key, label) in enumerate(segments):
        sep = "  " if i > 0 else ""
        segment_visible = len(sep) + len(key) + 1 + len(label)
        if visible_len + segment_visible > term_width:
            truncated = True
            break
        parts.append(f"{sep}{DIM}{key}{RESET} {label}")
        visible_len += segment_visible
    if truncated and visible_len < term_width:
        padding = term_width - visible_len - 1
        parts.append(f"{' ' * padding}{DIM}…{RESET}")
    return "".join(parts)


